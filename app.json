{
  "expo": {
    "name": "SpendLens",
    "slug": "SpendLens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/spendlens-logo-1024.png",
    "scheme": "spendlens",
    "userInterfaceStyle": "automatic",
    "ios": {},
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFB37B",
        "foregroundImage": "./assets/logo/spendlens-logo-1024.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.SpendLens"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/spendlens-logo-512.png"
    },
    "androidStatusBar": {
      "translucent": false,
      "barStyle": "dark-content",
      "backgroundColor": "#00000000"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/logo/spendlens-logo-1024.png",
          "imageWidth": 200
        }
      ],
      "expo-sharing",
      "@react-native-community/datetimepicker",
      ["expo-notifications", {}]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7dc30ede-29da-4125-997d-db3995b6736d"
      }
    }
  }
}
